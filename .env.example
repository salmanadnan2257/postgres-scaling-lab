# Password for the postgres superuser in every docker-compose stack (defaults to "postgres" if unset)
POSTGRES_PASSWORD=postgres

# Part 3 app: DSN of the primary (writes). Default matches the part_3 compose stack.
PRIMARY_DSN=postgresql://postgres:postgres@localhost:5436/events_db

# Part 3 app: comma-separated DSNs of the read replicas
REPLICA_DSNS=postgresql://postgres:postgres@localhost:5437/events_db,postgresql://postgres:postgres@localhost:5438/events_db

# Part 3 baseline app (app.py) only: single-node DSN
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/events_db
