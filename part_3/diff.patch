diff --git a/part_3/replica2.conf b/part_3/replica2.conf
new file mode 100644
index 0000000..1b072ff
--- /dev/null
+++ b/part_3/replica2.conf
@@ -0,0 +1,25 @@
+# Replica PostgreSQL configuration
+listen_addresses = '*'
+max_connections = 100
+shared_buffers = 128MB
+wal_level = replica
+hot_standby = on
+max_standby_archive_delay = 30s
+max_standby_streaming_delay = 30s
+hot_standby_feedback = on
+
+# Replication settings
+primary_conninfo = 'host=primary port=5432 user=postgres password=postgres application_name=replica2'
+primary_slot_name = 'replica2_slot'
+restore_command = '/bin/true'
+recovery_target_timeline = 'latest'
+
+# Performance tuning for read workload
+effective_cache_size = 256MB
+random_page_cost = 1.1
+maintenance_work_mem = 128MB
+
+# Logging for monitoring
+log_min_messages = warning
+log_min_error_statement = error
+log_min_duration_statement = 1000  # Log queries taking more than 1s
